# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/wealth_architect

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Messaging
SENDGRID_API_KEY=SG....
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Inngest
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# Feature flags
NEXT_PUBLIC_MODULE_LEDGER=true
NEXT_PUBLIC_MODULE_OPERATIONS=true
